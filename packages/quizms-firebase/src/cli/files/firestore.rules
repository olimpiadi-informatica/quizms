rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {
        function hasTimestamp(field) {
            return request.resource.data[field] == request.time;
        }

        function isAuthenticated(id) {
            return request.auth != null && request.auth.uid == id;
        }

        function affectedKeys() {
            return request.resource.data.diff(resource.data).affectedKeys();
        }

        function isTeacher() {
            return request.auth != null && request.auth.token.role == 'teacher';
        }

        function getVenue(id) {
            return get(/databases/$(database)/documents/venues/$(id));
        }

        function isTeacherVenue(venueId) {
            let venue = getVenue(venueId);
            return venue != null && venue.data.schoolId == request.auth.token.schoolId;
        }

        match /announcements/{announcement} {
            allow read: if isTeacher();
        }

        match /contests/{contest} {
            allow read: if true;
        }

        match /venues/{venueId} {
            allow read: if venueId == request.auth.token.venueId || resource.data.schoolId == request.auth.token.schoolId;
        }

        match /venues/{venueId}/students/{student} {
            function checkToken() {
                let venue = getVenue(venueId);
                return venue != null
                    && venue.data.token != null
                    && venue.data.token == request.resource.data.token
                    && venue.data.contestWindow.start == request.resource.data.contestRange.start
                    && venue.data.contestWindow.end >= request.resource.data.contestRange.end
                    && venue.data.contestId == request.resource.data.contestId
                    && request.time <= resource.data.contestRange.end + duration.value(10, 's');
            }

            function canStudentUpdate() {
                let keys = affectedKeys();
                return isAuthenticated(resource.data.uid)
                    && checkToken()
                    && keys.hasOnly(['answers', 'updatedAt', 'contestRange', 'extraData'])
                    && hasTimestamp('updatedAt');
            }

            function canTeacherUpdate() {
                let keys = affectedKeys();
                return isTeacherVenue(venueId)
                    && !keys.hasAny(['venueId', 'createdAt'])
                    && hasTimestamp('updatedAt');
            }

            allow read: if isAuthenticated(resource.data.uid) || isTeacherVenue(venueId);
            allow create: if isTeacherVenue(venueId) && request.resource.data.venueId == venueId;
            allow update: if canStudentUpdate() || canTeacherUpdate();
            allow delete: if isTeacherVenue(venueId);
        }

        match /studentRestores/{uid} {
            allow read: if isAuthenticated(uid) || isTeacherVenue(resource.data.venueId);
            allow update: if isTeacherVenue(resource.data.venueId);
            allow delete: if isTeacherVenue(resource.data.venueId);
        }

        match /variants/{variant} {
            allow read: if isTeacher();
        }

        match /websites/{website} {
            allow read: if true;
        }

        match /{document=**} {
            allow read, write: if request.auth.token.role == 'admin';
        }
    }
}
